# Remote state is REQUIRED for the apply job in CI to work.
# Local state (terraform.tfstate) is gitignored and does not persist between
# CI runs — without a remote backend, `terraform apply` in Actions would have
# no state and try to re-create resources that already exist.
#
# 1. Create an S3 bucket (versioning + encryption on) and a DynamoDB table
#    with a "LockID" (String) partition key for state locking.
# 2. Rename this file to backend.tf and fill in the values below.
# 3. Run `terraform init -migrate-state` locally once to move your existing
#    local state into S3.

terraform {
  backend "s3" {
    bucket         = "REPLACE_WITH_YOUR_STATE_BUCKET"
    key            = "user_management/terraform.tfstate"
    region         = "ap-south-1"
    dynamodb_table = "REPLACE_WITH_YOUR_LOCK_TABLE"
    encrypt        = true
  }
}
