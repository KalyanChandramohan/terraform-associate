# Local .terraform directories
**/.terraform/*

# Terraform state files — CONTAIN SECRETS IN PLAINTEXT, never commit
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may hold secrets
*.tfvars
*.tfvars.json
!example.tfvars

# CLI config / override files
.terraformrc
terraform.rc
*_override.tf
*_override.tf.json

# Keep the provider lock file committed (do NOT ignore .terraform.lock.hcl)
